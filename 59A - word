#include <iostream>
using namespace std;

int main() 
{
    string a; cin >> a;
    int upper = 0;
    int lower = 0;
    for (int i = 0; i < a.length(); i++){
        if (a[i] == toupper(a[i])) upper++;
        else lower++;
    }
    for (int i = 0; i < a.length(); i++){
        if (upper > lower){
            a[i] = toupper(a[i]);
        }
        else {
            a[i] = tolower(a[i]);
        }
    }
    cout << a;
    return 0;
}
