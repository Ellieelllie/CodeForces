#include <iostream>
using namespace std;

int main() 
{
    int n; cin >> n;
    string b; cin >> b;
    int d = 0;
    int a = 0;
    for (int i = 0; i < n; i++){
        if (b[i] == 'A') a++;
        else d++;
    }
    if (a>d) cout << "Anton";
    else if (a < d) cout << "Danik";
    else cout << "Friendship"; 
    return 0;
}
